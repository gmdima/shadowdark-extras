<div class="maphub-launcher">

    <div class="launcher-content">
        <div class="generator-card" data-generator="mfcg">
            <div class="generator-icon"><i class="fas fa-city"></i></div>
            <div class="generator-info">
                <h3>Medieval Fantasy City Generator</h3>
                <p>Generate detailed fantasy city maps with walls, districts, and rivers.</p>
            </div>
            <div class="generator-actions">
                <button class="open-generator" data-action="open-mfcg">Open</button>
            </div>
        </div>

        <div class="generator-card" data-generator="village">
            <div class="generator-icon"><i class="fas fa-house-chimney-window"></i></div>
            <div class="generator-info">
                <h3>Village Generator</h3>
                <p>Create organic, small-scale village settlements and farmlands.</p>
            </div>
            <div class="generator-actions">
                <button class="open-generator" data-action="open-village">Open</button>
            </div>
        </div>

        <div class="generator-card" data-generator="dwellings">
            <div class="generator-icon"><i class="fas fa-building"></i></div>
            <div class="generator-info">
                <h3>Dwellings Generator</h3>
                <p>Generate floorplans for individual houses, taverns, and manors.</p>
            </div>
            <div class="generator-actions">
                <button class="open-generator" data-action="open-dwellings">Open</button>
            </div>
        </div>

        <div class="generator-card" data-generator="cave">
            <div class="generator-icon"><i class="fas fa-dungeon"></i></div>
            <div class="generator-info">
                <h3>Cave / Glade Generator</h3>
                <p>Generate natural underground caverns or outdoor forest clearings.</p>
            </div>
            <div class="generator-actions">
                <button class="open-generator" data-action="open-cave">Open</button>
            </div>
        </div>
    </div>
</div>